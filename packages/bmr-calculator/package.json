{
  "name": "bmr-calculator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "//": "Dev-time entry points at raw source; Vite/vue-tsc compile TS+Vue on the fly. Phase 4 will repoint these at the built dist/.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
